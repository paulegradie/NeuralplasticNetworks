{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment 13.2 metrics row schema",
  "type": "object",
  "required": [
    "experiment_name",
    "analysis_id",
    "schema_version",
    "phase",
    "seed",
    "world_count",
    "route_length",
    "variant",
    "variant_family",
    "route_table_accuracy_all",
    "composition_accuracy_seen_routes",
    "composition_accuracy_suffix_routes",
    "first_step_context_accuracy"
  ],
  "properties": {
    "experiment_name": {"const": "exp13_2_baseline_suite"},
    "analysis_id": {"const": "exp13_2"},
    "schema_version": {"const": "exp13_2_metrics_v1"},
    "phase": {"enum": ["baseline_comparison", "capacity_pressure", "sequential_retention"]},
    "seed": {"type": "integer"},
    "world_count": {"type": "integer", "minimum": 1},
    "route_length": {"type": "integer", "minimum": 1},
    "routes_per_world": {"type": "integer", "minimum": 1},
    "modes": {"type": "integer", "minimum": 1},
    "variant": {"type": "string"},
    "variant_family": {"type": "string"},
    "route_table_accuracy_all": {"type": ["number", "null"]},
    "composition_accuracy_seen_routes": {"type": ["number", "null"]},
    "composition_accuracy_suffix_routes": {"type": ["number", "null"]},
    "first_step_context_accuracy": {"type": ["number", "null"]},
    "capacity_used": {"type": ["number", "integer", "null"]},
    "capacity_ratio": {"type": ["number", "null"]},
    "evictions": {"type": ["number", "integer", "null"]},
    "hash_collisions": {"type": ["number", "integer", "null"]},
    "retention_world": {"type": ["number", "integer", "null"]},
    "world_age_from_end": {"type": ["number", "integer", "null"]}
  },
  "additionalProperties": true
}
